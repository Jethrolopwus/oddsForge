# ─────────────────────────────────────────────────────────────
# OddsForge Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env to git.
# ─────────────────────────────────────────────────────────────

# ── Solana ────────────────────────────────────────────────────
# RPC endpoint — must match TXLINE_NETWORK (devnet ↔ devnet, mainnet ↔ mainnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Agent wallet private key.
# Accepts either:
#   - A JSON byte-array:  [12,34,56, ...]
#   - A base58 private key: 5Jv...
SOLANA_PRIVATE_KEY=[your-keypair-byte-array]

# ── TxLINE Network ────────────────────────────────────────────
# "mainnet" → https://txline.txodds.com  (program 9ExbZjAapQww1vfcisDmrngPinHTEfpjYRWMunJgcKaA)
# "devnet"  → https://txline-dev.txodds.com (program 6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J)
TXLINE_NETWORK=devnet

# TxLINE subscription service level:
#   1  = World Cup + Int Friendlies (60-second delayed data) — FREE on mainnet & devnet
#   12 = World Cup + Int Friendlies (real-time)             — FREE on mainnet
# Defaults: mainnet → 12, devnet → 1
TXLINE_SERVICE_LEVEL_ID=1

# Subscription duration in weeks (must be a multiple of 4; minimum 4)
TXLINE_DURATION_WEEKS=4

# ── OddsForge Anchor Program ──────────────────────────────────
# Deployed program ID from `anchor deploy` in packages/program/oddsforge-executor
PROGRAM_ID=3XVn1g5q5NbGB7r3u8dYfWsmZw1n3bqCFXjiawvDSBBe

# ── Yellowstone gRPC (Triton One) — OPTIONAL ──────────────────
# Geyser streams on-chain Position PDA updates in real-time, letting the
# agent confirm transaction landing without polling the RPC node.
#
# Without it the agent still works fully: odds ingestion, signal detection,
# position placement, and score-driven settlement all run normally. The only
# difference is that on-chain account confirmations are not streamed — the
# agent relies on its settlement timers and the scores feed instead.
#
# To enable: obtain an endpoint + token from https://triton.one and fill in
# both variables below. Leave either blank to disable Geyser entirely.
#
# Geyser endpoint — e.g. https://your-project.rpcpool.com
GEYSER_ENDPOINT=

# Access token for Triton One gRPC
GEYSER_TOKEN=

# ── Jito ─────────────────────────────────────────────────────
# Jito submits transactions as MEV bundles for priority block landing,
# reducing failed transactions and confirmation latency.
#
# Without it the agent still works fully: transactions are submitted via
# plain sendAndConfirmTransaction on the configured Solana RPC node.
# Settlement, signal detection, and scoring are unaffected. The only
# difference is that you lose Jito's bundle priority guarantee and tip-
# based priority ordering.
#
# To enable: set the URL to the matching Block Engine endpoint below.
# Leave blank to use plain RPC submission instead.
#
# Mainnet: https://mainnet.block-engine.jito.wtf
# Devnet:  https://devnet.block-engine.jito.wtf
JITO_BLOCK_ENGINE_URL=

# Tip paid per Jito bundle (in lamports). 100_000 = 0.0001 SOL.
# Only used when JITO_BLOCK_ENGINE_URL is set. Increase during busy blocks
# to improve bundle landing priority.
JITO_TIP_LAMPORTS=100000

# ── Strategy Tuning (optional) ────────────────────────────────
# Minimum signal score (0–100) required to place a position (default 60)
MIN_SIGNAL_SCORE=60

# Minimum stake per position in lamports (default 0.01 SOL = 10_000_000)
MIN_STAKE_LAMPORTS=10000000

# Maximum stake per position in lamports (default 0.1 SOL = 100_000_000)
MAX_STAKE_LAMPORTS=100000000

# ─────────────────────────────────────────────────────────────
# How TxLINE auth works (no API key to set manually):
#
# On startup the agent runs the full auth flow automatically:
#   1. POST /auth/guest/start           → guest JWT
#   2. program.methods.subscribe(...)   → on-chain subscription tx
#   3. POST /api/token/activate         → activated API token
#
# Both credentials are sent as headers on all data requests:
#   Authorization: Bearer <guest_jwt>
#   X-Api-Token:   <activated_api_token>
#
# Tokens are refreshed automatically every 6 hours.
#
# The free tier requires SOL for the on-chain subscribe transaction fee
# but does NOT require any TxL token purchase. Fund your wallet with
# enough SOL (a few lamports covers the fee on mainnet).
#
# Hackathon note: TxODDS waived commercial fees through July 19, 2026.
# Service level 12 gives real-time World Cup data at zero cost on mainnet.
# ─────────────────────────────────────────────────────────────
