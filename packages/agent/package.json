    "@solana/spl-token": "0.4.9",
    "@solana/web3.js": "1.98.0",
    "@triton-one/yellowstone-grpc": "1.0.0",
    "axios": "1.7.9",
    "bs58": "5.0.0",
    "dotenv": "16.4.7",
    "tweetnacl": "1.0.3"
  },
  "devDependencies": {
    "@types/node": "20.14.9",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.5.4"
  },
  "engines": {
    "node": ">=18"
  }
