{
  "name": "@oddsforge/agent",
  "version": "1.0.0",
  "description": "OddsForge autonomous on-chain trading agent — TxLINE SSE + Solana + Jito",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "lint": "eslint 'src/**/*.ts'",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "solana",
    "anchor",
    "jito",
    "txline",
